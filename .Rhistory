# Example: Perfect separation
set.seed(1)
# Create a binary outcome fully determined by x
x <- c(rep(0, 10), rep(1, 10))
y <- c(rep(0, 10), rep(1, 10))  # perfectly separated
# Fit logistic regression
model <- glm(y ~ x, family = binomial())
summary(model)
# Quasi-complete separation example
x <- c(rep(0, 10), rep(1, 10))
y <- c(rep(0, 9), 1, rep(1, 10))  # almost perfect
model2 <- glm(y ~ x, family = binomial())
summary(model2)
has_warning <- function(expr) {
warn <- FALSE
withCallingHandlers(
expr,
warning = function(w) {
warn <<- TRUE
invokeRestart("muffleWarning")  # suppress printing
}
)
return(warn)
}
# Data with complete separation
x <- rep(c(0, 1), each = 10)
y <- c(rep(0, 10), rep(1, 10))
dat <- data.frame(y, x)
# Detect warning
warning_detected <- has_warning(glm(y ~ x, data = dat, family = binomial()))
warning_detected
model2$coefficients
