# Example data
data_matrix <- matrix(c(10, 15, 20, 12, 18, 25),
nrow = 2,
byrow = TRUE,
dimnames = list(c("Group A", "Group B"), c("Category 1", "Category 2", "Category 3")))
# Create the side-by-side bar plot
barplot(data_matrix,
beside = TRUE,
legend.text = rownames(data_matrix),
col = c("lightblue", "lightcoral"),
main = "Side-by-Side Bar Plot",
xlab = "Categories",
ylab = "Values")
